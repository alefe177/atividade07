programa {
  funcao inicio() {
    inteiro pc, pc1
    escreva("Digite a quantidade de peças que a equipe A produziu:")
    leia(pc)
    escreva("Digite a quantidade de peças que a equipe B produziu:")
    leia(pc1)
    se (pc >  pc1)
    escreva("A equipe A produziu mais peças")
    senao
    escreva("A equipe B produziu mais peças")
  }
}

programa {
  funcao inicio() {
    real m1, m2, m3, media
    escreva("Digite a media de consumo da maquina 1:")
    leia(m1)
    escreva("Digite a medida de consumo da maquina 2:")
    leia(m2)
    escreva("Digite a medida de consumo da maquina 3:")
    leia(m3)
media = (m1 * m2 * m3) / 3 
escreva("A media de consumo das maquinas é ", media)
  }
}

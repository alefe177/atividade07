programa {
  funcao inicio() {
    
   real valorHora, horasTrabalhadas, total 



   escreva("Digite o valor da hora técnica: ")
   leia(valorHora)

   escreva("Digite a quantidade de horas trabalhadas: ")
   leia(horasTrabalhadas)

   total = valorHora * horasTrabalhadas

   escreva("Valor total do serviço: R$ ", total)
  }
}
